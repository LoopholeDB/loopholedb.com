---
const stats = [
  { val: '94%',  label: 'Legal Solution Rate' },
  { val: '98%',  label: 'Project Success' },
  { val: '550+', label: 'Projects Done' },
];
---

<section class="section" id="database">
  <div class="container attorneys__inner">

    <!-- Left -->
    <div class="attorneys__content">
      <span class="eyebrow">Expert Legal Team</span>
      <h2 class="t-h1 attorneys__headline">Meet Our Most<br/>Talented &amp; Qualified<br/>Attorneys</h2>
      <p class="t-body attorneys__body">
        When looking for an attorney, you want a professional with experience
        handling cases like yours — who maintains the highest ethical and
        customer service standards at every step.
      </p>
      <a href="#contact" class="btn btn--outline">Find an Attorney</a>

      <!-- Stats row -->
      <div class="attorneys__stats">
        {stats.map(s => (
          <div class="atty-stat">
            <span class="atty-stat__val">{s.val}</span>
            <span class="atty-stat__label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Right — decorative card stack -->
    <div class="attorneys__visual" aria-hidden="true">
      <div class="atty-card atty-card--bg">
        <div class="atty-card__avatar">
          <div class="atty-card__avatar-circle"></div>
        </div>
        <div>
          <p class="atty-card__name">Lead Counsel</p>
          <p class="atty-card__role">Verified Attorney</p>
        </div>
      </div>

      <div class="atty-pill atty-pill--tl">
        <span class="atty-pill__val">90%</span>
        <span class="atty-pill__label">Legal<br/>Solution</span>
      </div>
      <div class="atty-pill atty-pill--br">
        <span class="atty-pill__val">98%</span>
        <span class="atty-pill__label">Project<br/>Success</span>
      </div>
    </div>

  </div>
</section>

<style>
  .attorneys__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 5rem;
  }

  .attorneys__headline { margin-bottom: 1.25rem; }
  .attorneys__body     { margin-bottom: 2rem; max-width: 44ch; }

  .attorneys__stats {
    display: flex;
    gap: 2rem;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    flex-wrap: wrap;
  }

  .atty-stat__val {
    display: block;
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 600;
    line-height: 1;
    color: var(--color-text-dark);
  }
  .atty-stat__label {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }

  /* ── Visual ── */
  .attorneys__visual {
    position: relative;
    height: 480px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .atty-card--bg {
    width: 260px;
    background: var(--color-cream-dark);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 2rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    z-index: 1;
    position: relative;
  }
  .atty-card__avatar-circle {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--color-border);
  }
  .atty-card__name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 500;
  }
  .atty-card__role {
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-top: 0.2rem;
  }

  .atty-pill {
    position: absolute;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    padding: 0.7rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    box-shadow: 0 4px 18px rgba(0,0,0,0.08);
    z-index: 2;
  }
  .atty-pill--tl { top: 20%; left: 0; }
  .atty-pill--br { bottom: 20%; right: 0; }

  .atty-pill__val {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--color-text-dark);
    line-height: 1;
  }
  .atty-pill__label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    line-height: 1.35;
  }

  @media (max-width: 900px) {
    .attorneys__inner { grid-template-columns: 1fr; gap: 3rem; }
    .attorneys__visual { height: 300px; }
  }
</style>
