---
const services = [
  {
    icon: '⚖️',
    title: 'Business Law',
    body: 'Comprehensive coverage of legal business entities — from sole traders to complex corporate structures. Search statutes, cases, and regulatory guidance instantly.',
  },
  {
    icon: '🔒',
    title: 'Criminal Law',
    body: 'The body of law relating to crime. Precedent search across threatening, harmful, and unlawful conduct with linked sentencing guidelines.',
  },
  {
    icon: '🏛️',
    title: 'Family Law',
    body: 'A specialist practice area covering divorce, child custody, adoption, and family relationships. Whatever your situation, our database makes it familiar.',
  },
];
---

<section class="section section--tinted" id="services">
  <div class="container">

    <div class="services__header">
      <div>
        <span class="eyebrow">What We Cover</span>
        <h2 class="t-h1">The Areas Where<br/>We Practise Law</h2>
      </div>
      <p class="t-body services__intro">
        We offer a wide range of services to our customers and go the extra
        length to make sure justice is served in every case.
      </p>
    </div>

    <hr class="rule services__rule" />

    <div class="services__grid">
      {services.map((s, i) => (
        <article class="service-card">
          <div class="service-card__icon">{s.icon}</div>
          <h3 class="t-h3 service-card__title">{s.title}</h3>
          <p class="t-sm service-card__body">{s.body}</p>
          <a href="#contact" class="btn btn--link">Learn More →</a>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .services__header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: end;
    gap: 3rem;
    margin-bottom: 2.5rem;
  }
  .services__intro { max-width: 44ch; }
  .services__rule  { margin-bottom: 3rem; }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 2rem 1.75rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: box-shadow var(--transition), transform var(--transition);
  }
  .service-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
    transform: translateY(-3px);
  }

  .service-card__icon {
    width: 48px;
    height: 48px;
    background: var(--color-cream-dark);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
  }

  .service-card__title { color: var(--color-text-dark); }
  .service-card__body  { flex: 1; }

  @media (max-width: 900px) {
    .services__header { grid-template-columns: 1fr; }
    .services__grid   { grid-template-columns: 1fr; }
  }
</style>
