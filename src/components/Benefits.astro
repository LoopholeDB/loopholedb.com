---
const benefits = [
  {
    title: 'Plain-English Summaries',
    body: 'Every loophole is written in plain English — no jargon, no ambiguity. Just what the law actually says and how an ordinary person can use it.',
  },
  {
    title: 'Always Free',
    body: 'Access to legal knowledge should not depend on your income. Every entry in our database is completely free to read, with no sign-up required.',
  },
  {
    title: 'Need Specific Help?',
    body: 'For situations that require tailored guidance, you can submit a contact request. Our consulting service will connect you with the right expertise.',
  },
];
---

<section class="section section--dark" id="benefits">
  <div class="container benefits__inner">

    <!-- Left -->
    <div class="benefits__content">
      <span class="eyebrow">Why LoopholeDB</span>
      <h2 class="t-h1 benefits__headline">The Law Works<br/>For Those Who<br/>Know It</h2>
      <p class="t-body benefits__body">
        The wealthy have always had access to legal loopholes through expensive
        lawyers. We believe that knowledge should be available to everyone.
      </p>
      <a href="#contact" class="btn btn--ghost">Need Specific Help?</a>
    </div>

    <!-- Right -->
    <div class="benefits__list">
      {benefits.map(b => (
        <div class="benefit-item">
          <h3 class="benefit-item__title">{b.title}</h3>
          <p class="benefit-item__body">{b.body}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .benefits__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 5rem;
  }

  .benefits__headline {
    color: var(--color-cream);
    margin-bottom: 1.25rem;
  }
  .benefits__body {
    color: rgba(242,235,224,0.6);
    max-width: 42ch;
    margin-bottom: 2.5rem;
  }

  .benefits__list {
    display: flex;
    flex-direction: column;
  }

  .benefit-item {
    padding: 1.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .benefit-item:last-child { border-bottom: 1px solid rgba(255,255,255,0.1); }

  .benefit-item__title {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--color-cream);
    margin-bottom: 0.5rem;
  }
  .benefit-item__body {
    font-size: var(--text-sm);
    color: rgba(242,235,224,0.55);
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .benefits__inner { grid-template-columns: 1fr; gap: 3rem; }
  }
</style>
