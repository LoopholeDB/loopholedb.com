---
---

<section class="hero section" id="home">
  <div class="container hero__inner">

    <!-- Left column -->
    <div class="hero__left">
      <span class="eyebrow">Free Legal Loophole Database</span>
      <h1 class="t-hero hero__headline">
        Legal<br />
        <em>Loopholes</em><br />
        For Everyone
      </h1>
      <p class="t-body hero__sub">
        LoopholeDB is a free, plain-English database of legal loopholes, rights, and
        workarounds — the same knowledge expensive lawyers charge thousands to provide.
      </p>
      <p class="t-body hero__sub2">
        We research federal and state statutes, court rulings, and regulatory guidance — then distill each into a straightforward summary any person can read, understand, and act on. No legal degree required.
      </p>
      <div class="hero__actions">
        <a href="/us" id="hero-browse" class="btn btn--primary">Browse Categories</a>
        <a href="/quiz" class="btn btn--outline">Find Your Loopholes →</a>
      </div>
    </div>

    <!-- Right column — decorative stat stack -->
    <div class="hero__right">
      <div class="hero__watermark">LAW</div>

      <div class="hero__stat hero__stat--top">
        <span class="hero__stat-val">12</span>
        <span class="hero__stat-label">Areas of<br/>Law Covered</span>
      </div>

      <div class="hero__stat hero__stat-bottom">
        <span class="hero__stat-val">Free</span>
        <span class="hero__stat-label">Always &amp;<br/>Forever</span>
      </div>

      <div class="hero__badge">
        <span class="hero__badge-icon">▶</span>
        <span class="hero__badge-text">For<br/>Everyone</span>
      </div>

      <a href="/quiz" class="hero__ai-btn">
        <span class="hero__ai-label">Find Loopholes for Me</span>
      </a>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll">
    <span class="hero__scroll-line"></span>
    <span class="hero__scroll-text">Scroll</span>
  </div>
</section>

<style>
  .hero {
    min-height: 92vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
    padding-block: 5rem;
  }

  /* ── Left ── */
  .hero__headline {
    font-size: clamp(3.5rem, 7vw, 6.5rem);
    line-height: 0.95;
    margin-bottom: 1.5rem;
  }
  .hero__headline em {
    font-style: italic;
    font-weight: 300;
    color: var(--color-brown-mid);
  }
  .hero__sub {
    max-width: 42ch;
    margin-bottom: 1rem;
    font-size: 1.05rem;
  }
  .hero__sub2 {
    max-width: 48ch;
    margin-bottom: 2.5rem;
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  /* ── Right ── */
  .hero__right {
    position: relative;
    height: 480px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero__watermark {
    font-family: var(--font-display);
    font-size: clamp(8rem, 14vw, 14rem);
    font-weight: 700;
    color: var(--color-cream-dark);
    letter-spacing: -0.05em;
    user-select: none;
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 0;
  }

  /* central decorative rule box */
  .hero__right::before {
    content: '';
    position: absolute;
    inset: 10% 15%;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    z-index: 1;
  }

  .hero__stat {
    position: absolute;
    z-index: 2;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.07);
  }
  .hero__stat--top    { top: 18%; left: 0; }
  .hero__stat-bottom  { bottom: 18%; right: 0; }

  .hero__stat-val {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 600;
    line-height: 1;
    color: var(--color-text-dark);
  }
  .hero__stat-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .hero__badge {
    position: absolute;
    bottom: 8%;
    left: 8%;
    z-index: 2;
    width: 90px;
    height: 90px;
    border-radius: 50%;
    border: 1.5px solid var(--color-border);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    text-align: center;
    background: var(--color-cream);
  }
  .hero__badge-icon { font-size: 0.9rem; color: var(--color-text-dark); }
  .hero__badge-text { font-size: 0.55rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-muted); line-height: 1.3; }

  /* ── AI Agent button ── */
  .hero__ai-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.7rem 1.4rem;
    background: var(--color-text-dark);
    color: var(--color-cream);
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    white-space: nowrap;
    box-shadow: 0 6px 24px rgba(0,0,0,0.18);
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .hero__ai-btn:hover {
    background: var(--color-brown-mid);
    transform: translate(-50%, -50%) scale(1.04);
    box-shadow: 0 10px 32px rgba(0,0,0,0.22);
  }
  .hero__ai-icon {
    font-size: 1rem;
    line-height: 1;
  }

  /* ── Scroll indicator ── */
  .hero__scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .hero__scroll-line {
    display: block;
    width: 1px;
    height: 50px;
    background: var(--color-border);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  .hero__scroll-text {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    writing-mode: vertical-rl;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50%       { opacity: 1;   transform: scaleY(1.1); }
  }

  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      text-align: center;
      padding-block: 3rem;
    }
    .hero__sub  { margin-inline: auto; }
    .hero__actions { justify-content: center; }
    .hero__right { height: 300px; }
    .hero__scroll { display: none; }
  }
</style>

<script>
  const browse = document.getElementById('hero-browse') as HTMLAnchorElement | null;
  if (browse) {
    const r = localStorage.getItem('lhdb-region') ?? 'us';
    browse.href = `/${r}`;
  }
</script>
