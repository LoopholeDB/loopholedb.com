---
const links = {
  company: ['About', 'Careers', 'Blog', 'Press'],
  categories: ['Consumer Rights', 'Housing', 'Healthcare', 'Employment', 'Small Business'],
  legal: ['Privacy Policy', 'Terms of Service', 'Cookie Policy', 'Disclaimer'],
};
---

<footer class="footer section--dark">
  <div class="container footer__inner">

    <div class="footer__brand">
      <a href="/" class="footer__logo">LoopholeDB</a>
      <p class="footer__tagline">
        A free, plain-English database of legal loopholes — built to give everyone
        access to the same legal advantages the wealthy take for granted.
      </p>
      <p class="footer__email">
        <span class="eyebrow" style="margin-bottom:0.25rem; display:block;">Get in touch</span>
        <a href="mailto:followmoney.ca@gmail.com" class="footer__mail">followmoney.ca@gmail.com</a>
      </p>
      <p class="footer__geo">
        🇺🇸 🇨🇦 Currently covering <strong>US and Canada</strong>. We're expanding to more countries soon —
        <a href="mailto:followmoney.ca@gmail.com?subject=Country%20Request">send us a request</a>
        if you'd like us to cover your country.
      </p>
    </div>

    <nav class="footer__nav">
      <div class="footer__col">
        <p class="footer__col-title">Company</p>
        <ul>
          {links.company.map(l => <li><a href="#">{l}</a></li>)}
        </ul>
      </div>
      <div class="footer__col">
        <p class="footer__col-title">Categories</p>
        <ul>
          {links.categories.map(l => <li><a href="#">{l}</a></li>)}
        </ul>
      </div>
      <div class="footer__col">
        <p class="footer__col-title">Legal</p>
        <ul>
          {links.legal.map(l => (
            <li>
              <a href={l === 'Disclaimer' ? '/disclaimer' : '#'}>{l}</a>
            </li>
          ))}
        </ul>
      </div>
    </nav>

  </div>

  <div class="container footer__disclaimer">
    <p>
      <strong>Legal Disclaimer:</strong> Information on LoopholeDB.com is for general
      informational and educational purposes only. It does not constitute legal advice and
      must not be relied upon as such. No attorney-client relationship is formed by use of
      this site. Content reflects the law as of the date last verified and may not be current —
      laws change frequently and vary by jurisdiction. Nothing on this site guarantees any
      legal outcome. LoopholeDB expressly disclaims all liability for any loss arising from
      reliance on information published here. Use of this site is at your own risk.
      <a href="/disclaimer">Read our full disclaimer →</a>
    </p>
  </div>

  <div class="container footer__bottom">
    <p>© 2026 LoopholeDB. All rights reserved.</p>
    <nav class="footer__bottom-links">
      <a href="#home">Home</a>
      <a href="#services">Categories</a>
      <a href="#contact">Contact</a>
    </nav>
  </div>
</footer>

<style>
  .footer {
    padding-top: var(--space-lg);
    padding-bottom: 0;
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: var(--space-md);
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .footer__logo {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    color: var(--color-cream);
    display: block;
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }

  .footer__tagline {
    font-size: var(--text-sm);
    color: rgba(242,235,224,0.5);
    line-height: 1.7;
    max-width: 34ch;
    margin-bottom: 1.75rem;
  }

  .footer__mail {
    font-size: var(--text-sm);
    color: var(--color-cream);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(242,235,224,0.3);
  }
  .footer__mail:hover { text-decoration-color: var(--color-cream); }

  .footer__nav {
    display: contents;
  }

  .footer__col-title {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(242,235,224,0.45);
    margin-bottom: 1.25rem;
  }

  .footer__col ul {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer__col a {
    font-size: var(--text-sm);
    color: rgba(242,235,224,0.65);
    transition: color var(--transition);
  }
  .footer__col a:hover { color: var(--color-cream); }

  .footer__geo {
    margin-top: 1.5rem;
    font-size: var(--text-xs);
    color: rgba(242,235,224,0.55);
    line-height: 1.6;
    max-width: 34ch;
  }
  .footer__geo strong { color: rgba(242,235,224,0.8); font-weight: 600; }
  .footer__geo a {
    color: rgba(242,235,224,0.75);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: rgba(242,235,224,0.3);
    transition: color var(--transition);
  }
  .footer__geo a:hover { color: var(--color-cream); }

  .footer__disclaimer {
    padding-block: 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  .footer__disclaimer p {
    font-size: 0.7rem;
    line-height: 1.65;
    color: rgba(242,235,224,0.3);
    max-width: 100%;
  }
  .footer__disclaimer strong {
    color: rgba(242,235,224,0.45);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.65rem;
  }
  .footer__disclaimer a {
    color: rgba(242,235,224,0.45);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: rgba(242,235,224,0.2);
    transition: color var(--transition);
    white-space: nowrap;
  }
  .footer__disclaimer a:hover { color: rgba(242,235,224,0.7); }

  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1.5rem;
    font-size: var(--text-xs);
    color: rgba(242,235,224,0.35);
    letter-spacing: 0.05em;
  }

  .footer__bottom-links {
    display: flex;
    gap: 2rem;
  }
  .footer__bottom-links a {
    color: rgba(242,235,224,0.35);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
    transition: color var(--transition);
  }
  .footer__bottom-links a:hover { color: var(--color-cream); }

  @media (max-width: 900px) {
    .footer__inner { grid-template-columns: 1fr 1fr; }
    .footer__brand { grid-column: 1 / -1; }
  }
  @media (max-width: 600px) {
    .footer__inner { grid-template-columns: 1fr; }
    .footer__bottom { flex-direction: column; gap: 1rem; text-align: center; }
  }
</style>
