---
---

<section class="section cta-section section--tinted" id="contact">
  <div class="container cta__inner">

    <div class="cta__text">
      <span class="eyebrow">Need Specific Help?</span>
      <h2 class="t-h1 cta__headline">
        Contact Us &nbsp;
        <span class="cta__arrow">→</span>
        &nbsp;Let's Talk
      </h2>
      <p class="t-body cta__sub">
        If you need tailored guidance applying a loophole to your situation,
        submit a request and we will connect you with the right help within 24 hours.
      </p>
    </div>

    <form class="cta__form" novalidate>
      <div class="cta__row">
        <div class="cta__field">
          <label for="name" class="cta__label">Full Name</label>
          <input id="name" type="text" class="cta__input" placeholder="Jane Smith" />
        </div>
        <div class="cta__field">
          <label for="email" class="cta__label">Email Address</label>
          <input id="email" type="email" class="cta__input" placeholder="jane@example.com" />
        </div>
      </div>
      <div class="cta__field">
        <label for="message" class="cta__label">Your Situation</label>
        <textarea id="message" class="cta__input cta__input--ta" rows="4" placeholder="Briefly describe your situation and which area of law it relates to…"></textarea>
      </div>
      <button type="submit" class="btn btn--primary cta__submit">Send Message</button>
    </form>

  </div>
</section>

<style>
  .cta__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: start;
    gap: 5rem;
  }

  .cta__headline  { margin-bottom: 1rem; }
  .cta__sub       { max-width: 44ch; }
  .cta__arrow     { color: var(--color-text-muted); }

  .cta__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .cta__field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    margin-bottom: 1.25rem;
  }

  .cta__label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-mid);
  }

  .cta__input {
    background: var(--color-white);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.8rem 1rem;
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-dark);
    width: 100%;
    outline: none;
    transition: border-color var(--transition);
  }
  .cta__input::placeholder { color: var(--color-text-muted); }
  .cta__input:focus { border-color: var(--color-brown-cta); }
  .cta__input--ta { resize: vertical; }

  .cta__submit { margin-top: 0.25rem; }

  @media (max-width: 900px) {
    .cta__inner { grid-template-columns: 1fr; gap: 3rem; }
    .cta__row   { grid-template-columns: 1fr; }
  }
</style>
