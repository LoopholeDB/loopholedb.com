---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';

export async function getStaticPaths() {
  const loopholes = await getCollection('loopholes_ca');

  // CA entries use frontmatter `category` (slug form) and `slug` fields.
  // The glob loader sets entry.id = frontmatter slug when present.
  const byCategory = loopholes.reduce<Record<string, typeof loopholes>>((acc, entry) => {
    const cat = entry.data.category;
    (acc[cat] ??= []).push(entry);
    return acc;
  }, {});

  return Object.entries(byCategory).map(([categorySlug, entries]) => ({
    params: { category: categorySlug },
    props: { categorySlug, entries },
  }));
}

const categoryIcons: Record<string, string> = {
  'consumer-rights':        '🛒',
  'digital-privacy':        '🔐',
  'education':              '🎓',
  'employment-labor':       '💼',
  'estate-planning':        '📜',
  'financial-tax':          '💰',
  'government-bureaucracy': '🏛️',
  'healthcare':             '🏥',
  'housing-real-estate':    '🏠',
  'insurance':              '🛡️',
  'small-business':         '🏪',
  'travel':                 '✈️',
};

const categoryLabels: Record<string, string> = {
  'consumer-rights':        'Consumer Rights',
  'digital-privacy':        'Digital Privacy',
  'education':              'Education',
  'employment-labor':       'Employment & Labour',
  'estate-planning':        'Estate Planning',
  'financial-tax':          'Financial & Tax',
  'government-bureaucracy': 'Government & Bureaucracy',
  'healthcare':             'Healthcare',
  'housing-real-estate':    'Housing & Real Estate',
  'insurance':              'Insurance',
  'small-business':         'Small Business',
  'travel':                 'Travel',
};

const categoryDescriptions: Record<string, string> = {
  'consumer-rights':        'Know your rights as a buyer under federal and provincial consumer protection law. Chargebacks, warranties, refunds, and protections against unfair practices.',
  'digital-privacy':        'Your rights under PIPEDA and provincial privacy laws. Data access requests, breach notification, and what companies can legally do with your information.',
  'education':              'Student rights, RESP strategies, disability accommodations, and maximizing government education grants and tax credits.',
  'employment-labor':       'Wages, wrongful dismissal, workplace safety, and employee vs. contractor classification under federal and provincial law.',
  'estate-planning':        'Wills, trusts, probate, powers of attorney, and beneficiary strategies to minimise tax and transfer wealth efficiently.',
  'financial-tax':          'CRA procedures, RRSP/TFSA/FHSA strategies, deductions, credits, and tax obligations for individuals and families.',
  'government-bureaucracy': 'Access to Information requests, administrative appeals, licensing disputes, and navigating federal and provincial agencies.',
  'healthcare':             'Provincial health coverage, disability tax credits, private insurance disputes, and rights when dealing with the healthcare system.',
  'housing-real-estate':    'Tenant protections, eviction rules, the Principal Residence Exemption, FHSA strategies, and landlord disclosure requirements.',
  'insurance':              'Policy obligations, claim denials, bad faith practices, and what Canadian insurers must cover by law.',
  'small-business':         'Business formation, the Lifetime Capital Gains Exemption, contracts, licensing, and regulatory compliance for Canadian entrepreneurs.',
  'travel':                 'Passenger rights under APPR, flight delay compensation, hotel disputes, and travel insurance coverage for Canadians.',
};

const difficultyOrder: Record<string, number> = {
  'easy': 0, 'easy-intermediate': 1, 'medium': 2, 'intermediate': 2, 'hard': 3, 'advanced': 3,
};

const { categorySlug, entries } = Astro.props;

const categoryLabel = categoryLabels[categorySlug] ?? categorySlug.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
const icon = categoryIcons[categorySlug] ?? '⚖️';
const description = categoryDescriptions[categorySlug] ?? '';

const sorted = [...entries].sort(
  (a, b) => (difficultyOrder[a.data.difficulty.toLowerCase()] ?? 99) - (difficultyOrder[b.data.difficulty.toLowerCase()] ?? 99)
);

function capitalize(s: string) {
  return s.charAt(0).toUpperCase() + s.slice(1);
}

const pageUrl = `https://loopholedb.com/ca/${categorySlug}`;
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      'name': `${categoryLabel} Legal Loopholes (Canada) — LoopholeDB`,
      'url': pageUrl,
      'description': description,
    },
    {
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://loopholedb.com' },
        { '@type': 'ListItem', 'position': 2, 'name': 'Canada', 'item': 'https://loopholedb.com/ca' },
        { '@type': 'ListItem', 'position': 3, 'name': categoryLabel, 'item': pageUrl },
      ],
    },
  ],
};
---

<Layout
  title={`${categoryLabel} Legal Loopholes (Canada) — LoopholeDB`}
  description={`Browse ${sorted.length} free plain-English guides to Canadian legal loopholes in ${categoryLabel}. ${description}`}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <Nav />
  <main>

    <!-- ── Category Hero ─────────────────────────────── -->
    <section class="cat-hero section--dark">
      <div class="container cat-hero__inner">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <a href="/#services">All Categories</a>
          <span aria-hidden="true">›</span>
          <span>{categoryLabel}</span>
        </nav>

        <div class="cat-hero__top">
          <div class="cat-icon">{icon}</div>
          <div>
            <span class="eyebrow">Legal Category · Canada</span>
            <h1 class="t-h1 cat-hero__title">{categoryLabel}</h1>
          </div>
        </div>

        <p class="cat-hero__desc">{description}</p>

        <div class="cat-hero__meta">
          <span class="meta-pill">{sorted.length} {sorted.length === 1 ? 'Loophole' : 'Loopholes'}</span>
          <span class="meta-pill">🇨🇦 Canada</span>
          <span class="meta-pill">Free Access</span>
        </div>
      </div>
    </section>

    <!-- ── Loophole List ─────────────────────────────── -->
    <section class="section">
      <div class="container">
        <div class="list-header">
          <h2 class="t-h2">Available Loopholes</h2>
          <p class="t-body">
            Each entry below is a plain-English guide to a specific Canadian legal right, rule,
            or workaround — including the exact laws and regulations that back it up.
          </p>
        </div>

        <div class="lh-grid">
          {sorted.map(entry => {
            const slug = entry.id; // entry.id = frontmatter slug for CA entries
            const { title, difficulty, summary } = entry.data;
            return (
              <a href={`/ca/${categorySlug}/${slug}`} class="lh-card">
                <div class="lh-card__header">
                  <span class="chip chip--neutral">{capitalize(difficulty)}</span>
                </div>
                <h3 class="lh-card__title">{title}</h3>
                {summary && (
                  <p class="lh-card__summary">{summary}</p>
                )}
                <div class="lh-card__footer">
                  <span class="lh-card__region">🇨🇦 All Provinces & Territories</span>
                  <span class="lh-card__cta">Read Guide →</span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ── Bottom CTA ────────────────────────────────── -->
    <section class="section section--tinted cta-bottom">
      <div class="container cta-bottom__inner">
        <div>
          <span class="eyebrow">Need Specific Help?</span>
          <h2 class="t-h2">Not Sure How This<br/>Applies to You?</h2>
          <p class="t-body" style="margin-top:1rem; max-width:46ch;">
            Our consulting service connects you with the right guidance for your
            specific situation — no jargon, no hourly billing surprises.
          </p>
        </div>
        <a href="/#contact" class="btn btn--primary">Get in Touch →</a>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* ── Hero ─────────────────────────────────────────── */
  .cat-hero { padding-block: 4rem 3.5rem; }
  .cat-hero__inner { display: flex; flex-direction: column; gap: 1.5rem; }

  .cat-hero__top {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .cat-icon {
    width: 64px;
    height: 64px;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    flex-shrink: 0;
  }

  .cat-hero__title {
    color: var(--color-cream);
    text-transform: none;
    letter-spacing: 0.02em;
    font-size: clamp(1.8rem, 4vw, 3rem);
    margin-top: 0.25rem;
  }

  .cat-hero__desc {
    font-size: 1.05rem;
    color: rgba(242,235,224,0.6);
    max-width: 58ch;
    line-height: 1.75;
  }

  .cat-hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .meta-pill {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(242,235,224,0.5);
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 100px;
    padding: 0.35rem 0.85rem;
  }

  /* ── Breadcrumb ───────────────────────────────────── */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(242,235,224,0.4);
    flex-wrap: wrap;
  }
  .breadcrumb a { color: rgba(242,235,224,0.55); transition: color var(--transition); }
  .breadcrumb a:hover { color: var(--color-cream); }
  .breadcrumb span:last-child { color: rgba(242,235,224,0.75); }

  /* ── List header ──────────────────────────────────── */
  .list-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: end;
    gap: 2rem;
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  /* ── Loophole grid ────────────────────────────────── */
  .lh-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
  }

  .lh-card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.75rem;
    transition: box-shadow var(--transition), transform var(--transition), border-color var(--transition);
    cursor: pointer;
  }
  .lh-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.09);
    transform: translateY(-3px);
    border-color: var(--color-brown-mid);
  }

  .lh-card__header {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .chip {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.25rem 0.65rem;
    border-radius: 100px;
    border: 1px solid transparent;
  }
  .chip--neutral { background: var(--color-cream-dark); color: var(--color-text-mid); border-color: var(--color-border); }

  .lh-card__title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-text-dark);
    line-height: 1.35;
    flex: 1;
  }

  .lh-card__summary {
    font-size: var(--text-sm);
    color: var(--color-text-mid);
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .lh-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: 0.85rem;
    border-top: 1px solid var(--color-border);
    font-size: var(--text-xs);
  }
  .lh-card__region { color: var(--color-text-muted); font-weight: 500; }
  .lh-card__cta {
    color: var(--color-brown-cta);
    font-weight: 600;
    letter-spacing: 0.06em;
    transition: letter-spacing var(--transition);
  }
  .lh-card:hover .lh-card__cta { letter-spacing: 0.1em; }

  /* ── Bottom CTA ───────────────────────────────────── */
  .cta-bottom__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    flex-wrap: wrap;
  }

  /* ── Responsive ───────────────────────────────────── */
  @media (max-width: 768px) {
    .list-header { grid-template-columns: 1fr; }
    .cat-hero__top { flex-direction: column; align-items: flex-start; }
    .cta-bottom__inner { flex-direction: column; align-items: flex-start; }
  }
</style>
