---
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import AiPromptModal from '../../../components/AiPromptModal.astro';

export async function getStaticPaths() {
  const loopholes = await getCollection('loopholes_ca');
  return loopholes.map(entry => ({
    params: { category: entry.data.category, slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, category, difficulty, summary, lastUpdated, tags, template_url, template_label, ai_prompt } = entry.data;

const categoryLabels: Record<string, string> = {
  'credit-cards':           'If You Have a Credit Card',
  'care-about-privacy':     'If You Care About Privacy',
  'saving-for-retirement':  "If You're Saving for Retirement",
  'have-a-job':             'If You Have a Job',
  'planning-your-future':   "If You're Planning Your Future",
  'pay-taxes':              'If You Pay Taxes',
  'dealing-with-government':"If You're Dealing With Government",
  'have-medical-bills':     'If You Have Medical Bills',
  'own-a-home':             'If You Own a Home',
  'have-insurance':         'If You Have Insurance',
  'run-a-business':         'If You Run a Business',
  'travel-often':           'If You Travel',
};

const categorySlug = entry.data.category;
const categoryLabel = categoryLabels[categorySlug] ?? category;
const entrySlug = entry.id;

const pageUrl  = `https://loopholedb.com/ca/${categorySlug}/${entrySlug}`;
const metaDesc = summary ?? `Learn about the "${title}" loophole under Canadian law. Plain-English guide covering who qualifies, how it works, and the legal basis.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      'headline': title,
      'description': metaDesc,
      'url': pageUrl,
      'dateModified': lastUpdated,
      'publisher': {
        '@type': 'Organization',
        'name': 'LoopholeDB',
        'url': 'https://loopholedb.com',
      },
      'about': {
        '@type': 'Thing',
        'name': categoryLabel,
      },
    },
    {
      '@type': 'BreadcrumbList',
      'itemListElement': [
        { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://loopholedb.com' },
        { '@type': 'ListItem', 'position': 2, 'name': 'Canada', 'item': 'https://loopholedb.com/ca' },
        { '@type': 'ListItem', 'position': 3, 'name': categoryLabel, 'item': `https://loopholedb.com/ca/${categorySlug}` },
        { '@type': 'ListItem', 'position': 4, 'name': title, 'item': pageUrl },
      ],
    },
  ],
};

function capitalize(s: string) {
  return s.charAt(0).toUpperCase() + s.slice(1);
}
---

<Layout
  title={`${title} — LoopholeDB`}
  description={metaDesc}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <Nav />
  <main>

    <!-- ── Page Hero ────────────────────────────────── -->
    <section class="lh-hero section--dark">
      <div class="container lh-hero__inner">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <a href={`/ca/${categorySlug}`}>{categoryLabel}</a>
          <span aria-hidden="true">›</span>
          <span>{title}</span>
        </nav>

        <span class="eyebrow">{categoryLabel} · 🇨🇦 Canada</span>
        <h1 class="t-h1 lh-hero__title">{title}</h1>

        <div class="lh-badges">
          <span class="badge">
            <span class="badge__label">Difficulty</span>
            <span class="badge__val">{capitalize(difficulty)}</span>
          </span>
          <span class="badge">
            <span class="badge__label">Applies To</span>
            <span class="badge__val">All Provinces & Territories</span>
          </span>
          <span class="badge badge--muted">
            <span class="badge__label">Last Updated</span>
            <span class="badge__val">{lastUpdated}</span>
          </span>
        </div>

        <AiPromptModal
          prompt={ai_prompt ?? `Help me understand and apply the "${title}" loophole to my situation. Ask me questions about my circumstances and then give me a personalized step-by-step action plan.`}
          title={title}
        />
      </div>
    </section>

    <!-- ── Content ──────────────────────────────────── -->
    <section class="section lh-content">
      <div class="container lh-content__inner">
        <article class="prose">
          <Content />
        </article>

        <aside class="lh-sidebar">
          <div class="sidebar-card">
            <h2 class="sidebar-card__heading">Quick Facts</h2>
            <dl class="sidebar-dl">
              <div>
                <dt>Jurisdiction</dt>
                <dd>🇨🇦 Canada</dd>
              </div>
              <div>
                <dt>Difficulty</dt>
                <dd>{capitalize(difficulty)}</dd>
              </div>
              <div>
                <dt>Applies To</dt>
                <dd>All Provinces & Territories</dd>
              </div>
              <div>
                <dt>Last Updated</dt>
                <dd>{lastUpdated}</dd>
              </div>
            </dl>
          </div>

          {template_url && (
            <div class="sidebar-card sidebar-card--template">
              <span class="template-icon" aria-hidden="true">📄</span>
              <h2 class="sidebar-card__heading">Free Template</h2>
              <p>{template_label ?? 'Ready-to-use template for this loophole'}</p>
              <a href={template_url} class="btn btn--primary" style="margin-top:1.25rem; display:inline-flex;">Open Template →</a>
            </div>
          )}

          {tags && tags.length > 0 && (
            <div class="sidebar-card">
              <h2 class="sidebar-card__heading">Tags</h2>
              <div class="sidebar-tags">
                {tags.map(tag => <span class="sidebar-tag">{tag}</span>)}
              </div>
            </div>
          )}

          <div class="sidebar-card sidebar-card--cta">
            <span class="sidebar-ai-icon" aria-hidden="true">✦</span>
            <h2 class="sidebar-card__heading">Chat with AI Agent</h2>
            <p>Fill in your details and we'll open a personalised prompt in Perplexity AI.</p>
            <button
              id="ai-modal-trigger-sidebar"
              class="btn btn--primary"
              type="button"
              style="margin-top:1.25rem; display:inline-flex; width:100%; justify-content:center;"
            >Start Chat →</button>
          </div>

          <a href="/#services" class="sidebar-back">← Back to All Categories</a>
        </aside>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* ── Hero ─────────────────────────────────────────── */
  .lh-hero {
    padding-block: 4rem 3.5rem;
  }
  .lh-hero__inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .lh-hero__title {
    color: var(--color-cream);
    max-width: 22ch;
    text-transform: none;
    letter-spacing: 0.02em;
    font-size: clamp(1.8rem, 3.5vw, 3rem);
  }

  /* ── Breadcrumb ───────────────────────────────────── */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(242,235,224,0.4);
    flex-wrap: wrap;
  }
  .breadcrumb a { color: rgba(242,235,224,0.55); transition: color var(--transition); }
  .breadcrumb a:hover { color: var(--color-cream); }
  .breadcrumb span:last-child { color: rgba(242,235,224,0.75); }

  /* ── Badges ───────────────────────────────────────── */
  .lh-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.5rem;
  }
  .badge {
    display: inline-flex;
    flex-direction: column;
    gap: 0.15rem;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: var(--radius-sm);
    padding: 0.5rem 0.9rem;
  }
  .badge__label {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(242,235,224,0.4);
  }
  .badge__val {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-cream);
  }
  .badge--muted { opacity: 0.7; }

  /* ── Content layout ───────────────────────────────── */
  .lh-content__inner {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 4rem;
    align-items: start;
  }

  /* ── Prose ────────────────────────────────────────── */
  .prose { min-width: 0; }
  .prose :global(h1) { display: none; }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2.5vw, 1.9rem);
    font-weight: 400;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-dark);
    margin-top: 2.75rem;
    margin-bottom: 1rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--color-border);
  }
  .prose :global(h2:first-of-type) { margin-top: 0; }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--color-text-dark);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .prose :global(p) {
    color: var(--color-text-mid);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .prose :global(ol),
  .prose :global(ul) {
    padding-left: 1.25rem;
    margin-bottom: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .prose :global(ol) { list-style: decimal; }
  .prose :global(ul) { list-style: disc; }

  .prose :global(li) {
    color: var(--color-text-mid);
    line-height: 1.75;
    font-size: var(--text-body);
  }

  .prose :global(strong) {
    font-weight: 600;
    color: var(--color-text-dark);
  }

  .prose :global(a) {
    color: var(--color-brown-cta);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(75,53,32,0.35);
    transition: text-decoration-color var(--transition);
  }
  .prose :global(a:hover) { text-decoration-color: var(--color-brown-cta); }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    margin-bottom: 1.5rem;
  }
  .prose :global(th) {
    text-align: left;
    font-weight: 600;
    color: var(--color-text-dark);
    padding: 0.6rem 0.75rem;
    border-bottom: 2px solid var(--color-border);
  }
  .prose :global(td) {
    color: var(--color-text-mid);
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
  }

  /* ── Sidebar ──────────────────────────────────────── */
  .lh-sidebar {
    position: sticky;
    top: 5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .sidebar-card {
    background: var(--color-cream-dark);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.75rem;
  }
  .sidebar-card--cta {
    background: var(--color-espresso);
    border-color: transparent;
    color: var(--color-cream);
  }
  .sidebar-card--cta p {
    font-size: var(--text-sm);
    color: rgba(242,235,224,0.6);
    line-height: 1.65;
    margin-top: 0.5rem;
  }

  .sidebar-card--template {
    border-color: rgba(75,53,32,0.3);
    background: rgba(75,53,32,0.04);
  }
  .sidebar-card--template p {
    font-size: var(--text-sm);
    color: var(--color-text-mid);
    line-height: 1.65;
    margin-top: 0.35rem;
  }
  .sidebar-card--template .sidebar-card__heading {
    color: var(--color-brown-cta);
  }
  .template-icon {
    display: block;
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
  }

  .sidebar-card__heading {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-dark);
    margin-bottom: 1.25rem;
  }
  .sidebar-card--cta .sidebar-card__heading { color: var(--color-cream); }

  .sidebar-ai-icon {
    display: block;
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
    color: rgba(242,235,224,0.6);
  }

  .sidebar-dl {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .sidebar-dl > div {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--color-border);
    font-size: var(--text-sm);
  }
  .sidebar-dl > div:last-child { border-bottom: none; }
  .sidebar-dl dt {
    color: var(--color-text-muted);
    font-weight: 500;
    flex-shrink: 0;
  }
  .sidebar-dl dd {
    color: var(--color-text-dark);
    font-weight: 500;
    text-align: right;
  }

  .sidebar-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .sidebar-tag {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-mid);
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    padding: 0.2rem 0.6rem;
  }

  .sidebar-back {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    transition: color var(--transition);
    padding: 0.25rem 0;
  }
  .sidebar-back:hover { color: var(--color-text-dark); }

  /* ── Responsive ───────────────────────────────────── */
  @media (max-width: 900px) {
    .lh-content__inner {
      grid-template-columns: 1fr;
    }
    .lh-sidebar {
      position: static;
      order: -1;
    }
  }
</style>
