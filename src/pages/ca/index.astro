---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const categoryIcons: Record<string, string> = {
  'credit-cards':           '💳',
  'care-about-privacy':     '🔐',
  'saving-for-retirement':  '🎓',
  'have-a-job':             '💼',
  'planning-your-future':   '📜',
  'pay-taxes':              '💰',
  'dealing-with-government':'🏛️',
  'have-medical-bills':     '🏥',
  'own-a-home':             '🏠',
  'have-insurance':         '🛡️',
  'run-a-business':         '🏪',
  'travel-often':           '✈️',
};

const categoryTitles: Record<string, string> = {
  'credit-cards':           'If You Have a Credit Card',
  'care-about-privacy':     'If You Care About Privacy',
  'saving-for-retirement':  "If You're Saving for Retirement",
  'have-a-job':             'If You Have a Job',
  'planning-your-future':   "If You're Planning Your Future",
  'pay-taxes':              'If You Pay Taxes',
  'dealing-with-government':"If You're Dealing With Government",
  'have-medical-bills':     'If You Have Medical Bills',
  'own-a-home':             'If You Own a Home',
  'have-insurance':         'If You Have Insurance',
  'run-a-business':         'If You Run a Business',
  'travel-often':           'If You Travel',
};

const categoryDescriptions: Record<string, string> = {
  'credit-cards':           'Chargebacks, billing disputes, fraud protection, and rights you have as a cardholder under federal and provincial law.',
  'care-about-privacy':     'Your rights under PIPEDA and provincial privacy laws. Data access requests, breach notification, and how to make companies delete your information.',
  'saving-for-retirement':  'RESP strategies, RRSP/TFSA/FHSA loopholes, rollovers, and contribution rules that grow your savings faster.',
  'have-a-job':             'Wages, wrongful dismissal, workplace safety, and employee vs. contractor classification under federal and provincial law.',
  'planning-your-future':   'Wills, beneficiary designations, probate shortcuts, and ways to pass on assets without a lawyer or court.',
  'pay-taxes':              'CRA procedures, legal deductions, RRSP strategies, and loopholes that reduce what you owe.',
  'dealing-with-government':'How to get government records, appeal decisions, dispute fines, and navigate federal and provincial agencies.',
  'have-medical-bills':     'Disability tax credits, provincial health coverage gaps, private insurance disputes, and how to reduce what you pay.',
  'own-a-home':             'The Principal Residence Exemption, FHSA strategies, tenant protections, and rights homeowners often overlook.',
  'have-insurance':         'Claim rights, bad faith protections, diminished value claims, and what Canadian insurers must cover by law.',
  'run-a-business':         'The Lifetime Capital Gains Exemption, tax strategies, liability protections, and loopholes for Canadian entrepreneurs.',
  'travel-often':           'Passenger rights under APPR, compensation for delays and bumping, and protections most Canadian travellers never claim.',
};

const lhdbPath = path.resolve('LHDB/ca');
const categories = fs.readdirSync(lhdbPath, { withFileTypes: true })
  .filter(d => d.isDirectory())
  .map(d => ({
    slug: d.name,
    title: categoryTitles[d.name] ?? d.name.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()),
    icon: categoryIcons[d.name] ?? '⚖️',
    body: categoryDescriptions[d.name] ?? '',
    count: fs.readdirSync(path.join(lhdbPath, d.name)).filter(f => f.endsWith('.md')).length,
  }));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  'name': 'Canadian Legal Loopholes — LoopholeDB',
  'url': 'https://loopholedb.com/ca',
  'description': 'A free plain-English database of Canadian legal loopholes, rights, and workarounds. Browse all categories.',
  'breadcrumb': {
    '@type': 'BreadcrumbList',
    'itemListElement': [
      { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://loopholedb.com' },
      { '@type': 'ListItem', 'position': 2, 'name': 'Canada', 'item': 'https://loopholedb.com/ca' },
    ],
  },
};
---

<Layout
  title="Canadian Legal Loopholes — LoopholeDB"
  description="A free plain-English database of Canadian legal loopholes, rights, and workarounds. Browse all categories."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <Nav />
  <main>

    <section class="hero section--dark">
      <div class="container hero__inner">
        <span class="eyebrow">🇨🇦 Canada</span>
        <h1 class="t-h1 hero__title">Legal Loopholes<br/>for Canadians</h1>
        <p class="hero__sub">
          Browse our free, plain-English database of Canadian legal rights, rules, and workarounds —
          covering federal law and key provincial regulations.
        </p>
      </div>
    </section>

    <section class="section section--tinted">
      <div class="container">
        <div class="grid-header">
          <h2 class="t-h2">Browse by Category</h2>
          <p class="t-body">{categories.reduce((n, c) => n + c.count, 0)} loopholes across {categories.length} categories</p>
        </div>
        <div class="cat-grid">
          {categories.map(c => (
            <a href={`/ca/${c.slug}`} class="cat-card">
              <div class="cat-card__icon">{c.icon}</div>
              <div class="cat-card__body">
                <h3 class="cat-card__title">{c.title}</h3>
                <p class="cat-card__desc">{c.body}</p>
              </div>
              <span class="cat-card__count">{c.count} {c.count === 1 ? 'loophole' : 'loopholes'} →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .hero { padding-block: 5rem 4rem; }
  .hero__inner { display: flex; flex-direction: column; gap: 1.5rem; max-width: 52ch; }
  .hero__title {
    color: var(--color-cream);
    text-transform: none;
    letter-spacing: 0.02em;
    font-size: clamp(2rem, 5vw, 3.5rem);
  }
  .hero__sub {
    font-size: 1.05rem;
    color: rgba(242,235,224,0.6);
    line-height: 1.75;
  }

  .grid-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .grid-header .t-body { color: var(--color-text-muted); }

  .cat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .cat-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.75rem;
    transition: box-shadow var(--transition), transform var(--transition), border-color var(--transition);
  }
  .cat-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.09);
    transform: translateY(-3px);
    border-color: var(--color-brown-mid);
  }

  .cat-card__icon {
    width: 48px;
    height: 48px;
    background: var(--color-cream-dark);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    flex-shrink: 0;
  }

  .cat-card__title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--color-text-dark);
    margin-bottom: 0.4rem;
  }

  .cat-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-mid);
    line-height: 1.65;
    flex: 1;
  }

  .cat-card__count {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--color-brown-cta);
    margin-top: auto;
    transition: letter-spacing var(--transition);
  }
  .cat-card:hover .cat-card__count { letter-spacing: 0.12em; }

  @media (max-width: 900px) {
    .cat-grid { grid-template-columns: 1fr 1fr; }
    .grid-header { flex-direction: column; gap: 0.5rem; }
  }
  @media (max-width: 600px) {
    .cat-grid { grid-template-columns: 1fr; }
  }
</style>
