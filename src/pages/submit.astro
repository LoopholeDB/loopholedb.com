---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const categories = [
  { value: 'credit-cards',           label: 'If You Have a Credit Card' },
  { value: 'care-about-privacy',     label: 'If You Care About Privacy' },
  { value: 'saving-for-retirement',  label: "If You're Saving for Retirement" },
  { value: 'have-a-job',             label: 'If You Have a Job' },
  { value: 'planning-your-future',   label: "If You're Planning Your Future" },
  { value: 'pay-taxes',              label: 'If You Pay Taxes' },
  { value: 'dealing-with-government',label: "If You're Dealing With Government" },
  { value: 'have-medical-bills',     label: 'If You Have Medical Bills' },
  { value: 'own-a-home',             label: 'If You Own a Home' },
  { value: 'have-insurance',         label: 'If You Have Insurance' },
  { value: 'run-a-business',         label: 'If You Run a Business' },
  { value: 'travel-often',           label: 'If You Travel' },
];
---

<Layout
  title="Submit a Loophole — LoopholeDB"
  description="Know a legal loophole, right, or workaround that others should know about? Submit it to LoopholeDB and help level the playing field."
  noindex={true}
>
  <Nav />
  <main>

    <!-- ── Hero ─────────────────────────────────────── -->
    <section class="sub-hero section--dark">
      <div class="container sub-hero__inner">
        <span class="eyebrow">Community Submissions</span>
        <h1 class="t-h1 sub-hero__title">Submit a Loophole</h1>
        <p class="sub-hero__desc">
          Know a legal right, rule, or workaround that most people don't? Help us
          level the playing field — submit it and our team will research, verify,
          and publish it for free.
        </p>
        <div class="sub-hero__pills">
          <span class="info-pill">✓ Free to submit</span>
          <span class="info-pill">✓ Reviewed by our team</span>
          <span class="info-pill">✓ Credit given if published</span>
        </div>
      </div>
    </section>

    <!-- ── Form ──────────────────────────────────────── -->
    <section class="section">
      <div class="container form-wrap">

        <div class="form-sidebar">
          <div class="sidebar-info">
            <h2 class="sidebar-info__heading">What makes a good submission?</h2>
            <ul class="sidebar-info__list">
              <li>
                <span class="list-icon">⚖️</span>
                <span>Backed by a specific law, regulation, court ruling, or official policy</span>
              </li>
              <li>
                <span class="list-icon">🗣️</span>
                <span>Explainable in plain English — no law degree required to understand it</span>
              </li>
              <li>
                <span class="list-icon">🎯</span>
                <span>Genuinely useful — saves money, protects rights, or unlocks a benefit</span>
              </li>
              <li>
                <span class="list-icon">✅</span>
                <span>Legal and ethical — not a tax fraud scheme or illegal workaround</span>
              </li>
            </ul>
          </div>

          <div class="sidebar-info sidebar-info--muted">
            <h2 class="sidebar-info__heading">What happens next?</h2>
            <p>
              Our team reviews every submission. If your loophole is verified and published,
              we'll credit you by name (if you'd like). We aim to review submissions within
              2–4 weeks. We can't publish every submission, but we read them all.
            </p>
          </div>
        </div>

        <form
          class="submit-form"
          method="POST"
          action="https://formspree.io/f/xpqjoekn"
          id="loopholeForm"
          novalidate
        >

          <fieldset class="form-section">
            <legend class="form-section__title">About the Loophole</legend>

            <div class="field">
              <label class="field__label" for="title">
                Loophole Title <span class="required" aria-hidden="true">*</span>
              </label>
              <input
                class="field__input"
                type="text"
                id="title"
                name="title"
                placeholder="e.g. Credit Card Chargeback on Cancelled Services"
                required
                maxlength="120"
              />
              <p class="field__hint">Short, descriptive, plain-English name.</p>
            </div>

            <div class="field-row">
              <div class="field">
                <label class="field__label" for="country">
                  Country <span class="required" aria-hidden="true">*</span>
                </label>
                <select class="field__input field__select" id="country" name="country" required>
                  <option value="" disabled selected>Select country</option>
                  <option value="us">🇺🇸 United States</option>
                  <option value="ca">🇨🇦 Canada</option>
                  <option value="other">Other (specify in notes)</option>
                </select>
              </div>

              <div class="field">
                <label class="field__label" for="category">
                  Category <span class="required" aria-hidden="true">*</span>
                </label>
                <select class="field__input field__select" id="category" name="category" required>
                  <option value="" disabled selected>Select category</option>
                  {categories.map(c => (
                    <option value={c.value}>{c.label}</option>
                  ))}
                  <option value="other">Other / Not sure</option>
                </select>
              </div>
            </div>

            <div class="field">
              <label class="field__label" for="summary">
                Plain-English Summary <span class="required" aria-hidden="true">*</span>
              </label>
              <textarea
                class="field__input field__textarea"
                id="summary"
                name="summary"
                rows="4"
                placeholder="Explain the loophole in plain English. What is it? How does someone use it? Who benefits?"
                required
                maxlength="2000"
              ></textarea>
            </div>

            <div class="field">
              <label class="field__label" for="legal_basis">
                Legal Basis <span class="required" aria-hidden="true">*</span>
              </label>
              <textarea
                class="field__input field__textarea"
                id="legal_basis"
                name="legal_basis"
                rows="3"
                placeholder="Cite the specific law, regulation, court case, or official policy that makes this valid. e.g. 15 U.S.C. § 1666 — Fair Credit Billing Act"
                required
                maxlength="1000"
              ></textarea>
              <p class="field__hint">The more specific, the better. Links to official sources are very helpful.</p>
            </div>

            <div class="field">
              <label class="field__label" for="who_benefits">
                Who Benefits
              </label>
              <textarea
                class="field__input field__textarea"
                id="who_benefits"
                name="who_benefits"
                rows="2"
                placeholder="e.g. Any consumer who paid by credit card for a service that was not delivered"
                maxlength="500"
              ></textarea>
            </div>
          </fieldset>

          <fieldset class="form-section">
            <legend class="form-section__title">About You <span class="form-section__optional">(optional)</span></legend>

            <div class="field-row">
              <div class="field">
                <label class="field__label" for="name">Your Name</label>
                <input
                  class="field__input"
                  type="text"
                  id="name"
                  name="name"
                  placeholder="How you'd like to be credited"
                  maxlength="100"
                />
              </div>

              <div class="field">
                <label class="field__label" for="email">Your Email</label>
                <input
                  class="field__input"
                  type="email"
                  id="email"
                  name="email"
                  placeholder="So we can notify you if it's published"
                  maxlength="200"
                />
              </div>
            </div>

            <div class="field">
              <label class="field__label" for="notes">Additional Notes or Sources</label>
              <textarea
                class="field__input field__textarea"
                id="notes"
                name="notes"
                rows="3"
                placeholder="Any extra context, links to articles, court decisions, or government pages that support this loophole."
                maxlength="1000"
              ></textarea>
            </div>
          </fieldset>

          <div class="form-footer">
            <p class="form-disclaimer">
              By submitting you confirm this loophole is legal, ethical, and based on verifiable
              sources. We do not publish submissions that promote illegal activity.
            </p>
            <button type="submit" class="btn btn--primary btn--lg" id="submitBtn">
              Submit Loophole →
            </button>
          </div>

        </form>

      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script>
  const form = document.getElementById('loopholeForm') as HTMLFormElement | null;
  const btn  = document.getElementById('submitBtn')   as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    if (btn) {
      btn.disabled = true;
      btn.textContent = 'Submitting…';
    }
    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });
      if (res.ok) {
        form.innerHTML = `
          <div class="success-state">
            <div class="success-icon">✓</div>
            <h2 class="success-title">Submission Received</h2>
            <p class="success-body">
              Thanks for contributing! Our team will review your loophole and reach out
              if we have questions. We aim to respond within 2–4 weeks.
            </p>
            <a href="/" class="btn btn--primary" style="margin-top:2rem; display:inline-flex;">Back to Home</a>
          </div>`;
      } else {
        throw new Error('Server error');
      }
    } catch {
      if (btn) {
        btn.disabled = false;
        btn.textContent = 'Submit Loophole →';
      }
      alert('Something went wrong. Please try again or email us at followmoney.ca@gmail.com');
    }
  });
</script>

<style>
  /* ── Hero ─────────────────────────────────────────── */
  .sub-hero { padding-block: 4rem 3.5rem; }
  .sub-hero__inner { display: flex; flex-direction: column; gap: 1.5rem; max-width: 60ch; }
  .sub-hero__title {
    color: var(--color-cream);
    text-transform: none;
    letter-spacing: 0.02em;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
  }
  .sub-hero__desc {
    font-size: 1.05rem;
    color: rgba(242,235,224,0.6);
    line-height: 1.75;
  }
  .sub-hero__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
  .info-pill {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    color: rgba(242,235,224,0.6);
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 100px;
    padding: 0.3rem 0.85rem;
  }

  /* ── Layout ───────────────────────────────────────── */
  .form-wrap {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* ── Sidebar ──────────────────────────────────────── */
  .form-sidebar {
    position: sticky;
    top: 5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .sidebar-info {
    background: var(--color-cream-dark);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
  }
  .sidebar-info--muted { opacity: 0.75; }

  .sidebar-info__heading {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-dark);
    margin-bottom: 1rem;
  }

  .sidebar-info__list {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    list-style: none;
    padding: 0;
  }
  .sidebar-info__list li {
    display: flex;
    gap: 0.75rem;
    font-size: var(--text-sm);
    color: var(--color-text-mid);
    line-height: 1.55;
  }
  .list-icon { flex-shrink: 0; }

  .sidebar-info p {
    font-size: var(--text-sm);
    color: var(--color-text-mid);
    line-height: 1.65;
  }

  /* ── Form ─────────────────────────────────────────── */
  .submit-form {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .form-section {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-section__title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-dark);
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
    width: 100%;
  }
  .form-section__optional {
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    text-transform: none;
    font-family: var(--font-body, sans-serif);
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .field__label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-dark);
  }

  .required { color: var(--color-brown-cta); }

  .field__input {
    background: var(--color-cream-dark);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.75rem 1rem;
    font-size: var(--text-body);
    color: var(--color-text-dark);
    font-family: inherit;
    transition: border-color var(--transition), box-shadow var(--transition);
    width: 100%;
  }
  .field__input::placeholder { color: var(--color-text-muted); }
  .field__input:focus {
    outline: none;
    border-color: var(--color-brown-mid);
    box-shadow: 0 0 0 3px rgba(139,100,63,0.12);
  }
  .field__input:invalid:not(:placeholder-shown) {
    border-color: #dc2626;
  }

  .field__select { appearance: none; cursor: pointer; }
  .field__textarea { resize: vertical; min-height: 80px; line-height: 1.6; }

  .field__hint {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* ── Footer ───────────────────────────────────────── */
  .form-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    padding-top: 0.5rem;
  }

  .form-disclaimer {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 44ch;
  }

  .btn--lg { padding: 0.9rem 2rem; font-size: 0.95rem; }

  /* ── Success state ────────────────────────────────── */
  .success-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 4rem 2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }
  .success-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    color: #15803d;
    font-size: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
  }
  .success-title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: var(--color-text-dark);
    margin-bottom: 0.75rem;
  }
  .success-body {
    color: var(--color-text-mid);
    line-height: 1.75;
    max-width: 44ch;
  }

  /* ── Responsive ───────────────────────────────────── */
  @media (max-width: 900px) {
    .form-wrap { grid-template-columns: 1fr; }
    .form-sidebar { position: static; }
    .field-row { grid-template-columns: 1fr; }
    .form-footer { flex-direction: column; align-items: flex-start; }
  }
</style>
