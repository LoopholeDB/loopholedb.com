---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const lastUpdated = '2026-03-13';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  'name': 'Privacy Policy — LoopholeDB',
  'url': 'https://loopholedb.com/privacy',
  'description': 'Privacy policy for LoopholeDB.com, explaining what data we collect, how we use it, and your rights.',
  'publisher': {
    '@type': 'Organization',
    'name': 'LoopholeDB',
    'url': 'https://loopholedb.com',
  },
};
---

<Layout
  title="Privacy Policy — LoopholeDB"
  description="Privacy policy for LoopholeDB.com, explaining what data we collect, how we use it, and your rights."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <Nav />
  <main>

    <section class="hero section--dark">
      <div class="container hero__inner">
        <span class="eyebrow">Legal</span>
        <h1 class="t-h1 hero__title">Privacy Policy</h1>
        <p class="hero__meta">LoopholeDB.com · Last updated <time datetime={lastUpdated}>{lastUpdated}</time></p>
      </div>
    </section>

    <section class="section">
      <div class="container page__inner">

        <nav class="toc" aria-label="On this page">
          <p class="toc__heading">On this page</p>
          <ol>
            <li><a href="#overview">Overview</a></li>
            <li><a href="#data-collected">Data We Collect</a></li>
            <li><a href="#analytics">Analytics & Tracking</a></li>
            <li><a href="#cookies">Cookies</a></li>
            <li><a href="#third-parties">Third-Party Services</a></li>
            <li><a href="#your-rights">Your Rights</a></li>
            <li><a href="#retention">Data Retention</a></li>
            <li><a href="#contact">Contact</a></li>
          </ol>
        </nav>

        <article class="prose">

          <section id="overview">
            <h2>1. Overview</h2>
            <p>
              LoopholeDB.com ("we", "us", "our") is committed to protecting your privacy. This
              policy explains what information we collect when you visit <strong>loopholedb.com</strong>,
              how we use it, and what choices you have.
            </p>
            <p>
              By using this website you acknowledge that you have read and understood this policy.
              If you do not agree with it, please do not use the site.
            </p>
          </section>

          <section id="data-collected">
            <h2>2. Data We Collect</h2>
            <p>
              We do not require you to create an account or provide any personal information to
              use LoopholeDB. However, like most websites, certain technical data is collected
              automatically when you visit:
            </p>
            <ul>
              <li><strong>Log data</strong> — your browser type, operating system, referring URL, pages visited, and the date/time of your visit. This data is collected by our hosting provider and analytics tools.</li>
              <li><strong>Usage data</strong> — pages you view, links you click, and how long you spend on each page, collected via analytics tools (see below).</li>
              <li><strong>Session recordings & heatmaps</strong> — anonymised recordings of mouse movements, clicks, and scrolling behaviour, collected via Microsoft Clarity (see below).</li>
              <li><strong>Submitted content</strong> — if you submit a loophole suggestion via our contact or submission form, we collect the information you voluntarily provide (e.g., your email address and submission details).</li>
            </ul>
            <p>We do not knowingly collect personal data from children under the age of 13.</p>
          </section>

          <section id="analytics">
            <h2>3. Analytics &amp; Tracking</h2>
            <p>We use two analytics services to understand how visitors use the site:</p>
            <p>
              <strong>Google Analytics (GA4)</strong> — provided by Google LLC. Google Analytics
              collects anonymised usage data such as page views, session duration, and general
              geographic location (country/region level). Data is processed by Google in accordance
              with their privacy policy. You can opt out using the
              <a href="https://tools.google.com/dlpage/gaoptout" target="_blank" rel="noopener noreferrer">Google Analytics Opt-out Browser Add-on</a>.
            </p>
            <p>
              <strong>Microsoft Clarity</strong> — provided by Microsoft Corporation. Clarity
              records anonymised session replays and generates heatmaps to help us understand
              usability issues. Clarity may collect data including mouse movements, clicks,
              scroll depth, and page interactions. Microsoft processes this data in accordance
              with the
              <a href="https://privacy.microsoft.com/en-us/privacystatement" target="_blank" rel="noopener noreferrer">Microsoft Privacy Statement</a>.
              You can learn more about Clarity's data practices at
              <a href="https://clarity.microsoft.com" target="_blank" rel="noopener noreferrer">clarity.microsoft.com</a>.
            </p>
            <p>
              Neither service is used to personally identify individual visitors, and we do not
              combine analytics data with any other personally identifying information.
            </p>
          </section>

          <section id="cookies">
            <h2>4. Cookies</h2>
            <p>
              Cookies are small text files stored on your device by your browser. LoopholeDB
              itself does not set first-party cookies beyond what is strictly necessary for the
              site to function. However, our third-party analytics providers set their own cookies:
            </p>
            <ul>
              <li><strong>Google Analytics</strong> — sets cookies such as <code>_ga</code> and <code>_gid</code> to distinguish users and sessions. These cookies expire after up to 2 years.</li>
              <li><strong>Microsoft Clarity</strong> — sets cookies such as <code>_clsk</code> and <code>_clck</code> to identify sessions and users for replay and heatmap purposes. These cookies expire after up to 1 year.</li>
            </ul>
            <p>
              You can control or disable cookies through your browser settings. Note that disabling
              cookies may affect the functionality of some websites but will not affect your ability
              to read content on LoopholeDB.
            </p>
          </section>

          <section id="third-parties">
            <h2>5. Third-Party Services</h2>
            <p>
              In addition to the analytics services listed above, LoopholeDB may use the following
              third-party services, each of which operates under its own privacy policy:
            </p>
            <ul>
              <li><strong>Hosting / CDN</strong> — our site is served via a hosting provider that may log standard server access data.</li>
              <li><strong>Email</strong> — if you contact us by email, your message will be processed by our email provider.</li>
            </ul>
            <p>
              We do not sell, rent, or trade your personal information to any third parties for
              their own marketing purposes.
            </p>
          </section>

          <section id="your-rights">
            <h2>6. Your Rights</h2>
            <p>
              Depending on where you are located, you may have rights regarding your personal data:
            </p>
            <ul>
              <li><strong>EU/EEA &amp; UK residents (GDPR/UK GDPR)</strong> — you have the right to access, rectify, erase, restrict, or object to processing of your personal data, and the right to data portability. You also have the right to lodge a complaint with your local supervisory authority.</li>
              <li><strong>California residents (CCPA)</strong> — you have the right to know what personal information is collected about you, to request deletion, and to opt out of the "sale" or "sharing" of your personal information. Note that analytics data shared with Google and Microsoft may constitute "sharing" under CCPA. To opt out, use the browser opt-out tools linked in Section 3, or contact us directly.</li>
              <li><strong>Canadian residents (PIPEDA)</strong> — you have the right to access personal information we hold about you and to challenge its accuracy.</li>
            </ul>
            <p>
              To exercise any of these rights, please contact us at the email address in Section 8.
              We will respond within 30 days.
            </p>
          </section>

          <section id="retention">
            <h2>7. Data Retention</h2>
            <p>
              We retain analytics data for as long as permitted by each third-party provider's
              default retention settings (typically 14 months for Google Analytics and 30 days
              for Clarity session recordings). Email correspondence is retained for as long as
              necessary to respond to your enquiry.
            </p>
          </section>

          <section id="contact">
            <h2>8. Contact</h2>
            <p>
              If you have questions about this privacy policy, wish to exercise your data rights,
              or want to report a privacy concern, please contact us at:
            </p>
            <p>
              <a href="mailto:followmoney.ca@gmail.com">followmoney.ca@gmail.com</a>
            </p>
            <p>
              We may update this policy from time to time. When we do, we will revise the
              "Last updated" date at the top of this page. Continued use of the site after
              any update constitutes your acceptance of the revised policy.
            </p>
          </section>

        </article>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* ── Hero ─────────────────────────────────────────── */
  .hero { padding-block: 4rem 3rem; }
  .hero__inner { display: flex; flex-direction: column; gap: 1rem; }
  .hero__title {
    color: var(--color-cream);
    text-transform: none;
    letter-spacing: 0.02em;
    font-size: clamp(2rem, 4vw, 3rem);
  }
  .hero__meta {
    font-size: var(--text-xs);
    color: rgba(242,235,224,0.4);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* ── Layout ───────────────────────────────────────── */
  .page__inner {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 5rem;
    align-items: start;
  }

  /* ── TOC ──────────────────────────────────────────── */
  .toc {
    position: sticky;
    top: 5rem;
    background: var(--color-cream-dark);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.25rem 1.5rem;
  }
  .toc__heading {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.85rem;
  }
  .toc ol {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    list-style: none;
    padding: 0;
    counter-reset: toc;
  }
  .toc a {
    font-size: var(--text-sm);
    color: var(--color-text-mid);
    transition: color var(--transition);
    line-height: 1.4;
  }
  .toc a:hover { color: var(--color-text-dark); }

  /* ── Prose ────────────────────────────────────────── */
  .prose {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .prose section {
    padding-bottom: 2.5rem;
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .prose section:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .prose h2 {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.5vw, 1.7rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-dark);
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .prose p {
    color: var(--color-text-mid);
    line-height: 1.85;
    margin-bottom: 1rem;
    font-size: var(--text-body);
  }
  .prose p:last-child { margin-bottom: 0; }

  .prose strong {
    font-weight: 600;
    color: var(--color-text-dark);
  }

  .prose code {
    font-family: monospace;
    font-size: 0.9em;
    background: var(--color-cream-dark);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    padding: 0.1em 0.4em;
  }

  .prose ul, .prose ol {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .prose ul { list-style: disc; }
  .prose ol { list-style: decimal; }

  .prose li {
    color: var(--color-text-mid);
    line-height: 1.75;
    font-size: var(--text-body);
  }

  .prose a {
    color: var(--color-brown-cta);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(75,53,32,0.3);
    transition: text-decoration-color var(--transition);
  }
  .prose a:hover { text-decoration-color: var(--color-brown-cta); }

  /* ── Responsive ───────────────────────────────────── */
  @media (max-width: 768px) {
    .page__inner { grid-template-columns: 1fr; }
    .toc { position: static; }
  }
</style>
