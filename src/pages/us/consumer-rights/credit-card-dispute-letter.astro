---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
---

<Layout
  title="Credit Card Dispute Letter Template — LoopholeDB"
  description="Free fill-in-the-blank credit card dispute letter template under the Fair Credit Billing Act (FCBA). Print or save as PDF."
>
  <Nav />
  <main>
    <div class="template-toolbar no-print">
      <div class="toolbar-inner">
        <a href="/us/consumer-rights/credit-card-chargeback-rights" class="toolbar-back">← Credit Card Chargeback Rights</a>
        <div class="toolbar-actions">
          <p class="toolbar-hint">Fill in the <mark>[BRACKETED FIELDS]</mark>, then print or save as PDF.</p>
          <button onclick="window.print()" class="btn btn--primary">Print / Save as PDF</button>
        </div>
      </div>
    </div>

    <div class="doc-wrap">
      <article class="document">

        <div class="doc-sender">
          <p>[YOUR FULL NAME]</p>
          <p>[YOUR STREET ADDRESS]</p>
          <p>[CITY, STATE, ZIP CODE]</p>
          <p>[YOUR PHONE NUMBER]</p>
          <p>[YOUR EMAIL ADDRESS]</p>
        </div>

        <p class="doc-date">[DATE]</p>

        <div class="doc-recipient">
          <p>[CREDIT CARD ISSUER NAME]</p>
          <p>Billing Inquiries Department</p>
          <p>[ISSUER MAILING ADDRESS]</p>
          <p>[CITY, STATE, ZIP CODE]</p>
        </div>

        <p class="doc-re"><strong>Re: Notice of Billing Dispute — Account ending in [LAST 4 DIGITS]</strong></p>

        <p>Dear Sir or Madam:</p>

        <p>
          I am writing to formally dispute a billing error on the above-referenced account pursuant to the Fair Credit Billing Act (FCBA), 15 U.S.C. § 1666 <em>et seq.</em>
        </p>

        <p><strong>Disputed charge:</strong></p>
        <ul>
          <li>Merchant: [MERCHANT NAME]</li>
          <li>Date of charge: [DATE CHARGE POSTED]</li>
          <li>Amount: $[AMOUNT]</li>
          <li>Appeared on my: [MONTH/YEAR] statement</li>
        </ul>

        <p><strong>Reason for dispute</strong> (check all that apply):</p>
        <ul class="checklist">
          <li>☐ This charge was not made by me or any authorized user on my account</li>
          <li>☐ The merchandise was never delivered / service was never rendered</li>
          <li>☐ The merchandise or service was materially not as described or advertised</li>
          <li>☐ I was charged an incorrect amount</li>
          <li>☐ I returned the merchandise and the credit was not applied</li>
          <li>☐ Other: [DESCRIBE THE BILLING ERROR IN DETAIL]</li>
        </ul>

        <p>
          Pursuant to 15 U.S.C. § 1666(a), I request that you investigate this billing error and correct my account accordingly. I understand that:
        </p>
        <ul>
          <li>I am not required to pay the disputed amount while the investigation is pending;</li>
          <li>You may not report this amount as delinquent to any credit reporting agency during the investigation period; and</li>
          <li>You must acknowledge this notice within 30 days and resolve the dispute within two billing cycles (not to exceed 90 days).</li>
        </ul>

        <p>
          I have enclosed copies of the following documentation supporting my dispute:
        </p>
        <ul>
          <li>[e.g., Order confirmation email showing what was advertised]</li>
          <li>[e.g., Photos of merchandise received showing the discrepancy]</li>
          <li>[e.g., Correspondence with the merchant showing their refusal to resolve]</li>
          <li>[e.g., Credit card statement showing the disputed charge]</li>
        </ul>

        <p>
          Please confirm receipt of this dispute and advise me of the outcome in writing. If you need additional information, I can be reached at the phone number or email address listed above.
        </p>

        <p>Sincerely,</p>

        <div class="doc-sig">
          <div class="sig-line"></div>
          <p>[YOUR PRINTED NAME]</p>
        </div>

        <p class="doc-enclosures"><strong>Enclosures:</strong> [List each document enclosed]</p>

        <div class="doc-footer-note no-print">
          <p><strong>Note:</strong> Send this letter via certified mail with return receipt requested to preserve your full legal rights. Keep a copy for your records. The 60-day window runs from the date the disputed charge appeared on your statement.</p>
        </div>

      </article>
    </div>
  </main>
  <div class="no-print"><Footer /></div>
</Layout>

<style>
  /* ── Toolbar ── */
  .template-toolbar {
    background: var(--color-espresso);
    padding: 0.85rem 0;
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .toolbar-inner {
    max-width: var(--max-w);
    margin-inline: auto;
    padding-inline: 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .toolbar-back {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(242,235,224,0.6);
    transition: color var(--transition);
    white-space: nowrap;
  }
  .toolbar-back:hover { color: var(--color-cream); }
  .toolbar-actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .toolbar-hint {
    font-size: var(--text-sm);
    color: rgba(242,235,224,0.55);
  }
  .toolbar-hint mark {
    background: rgba(242,235,224,0.15);
    color: var(--color-cream);
    border-radius: 3px;
    padding: 0.1em 0.3em;
  }

  /* ── Document wrapper ── */
  .doc-wrap {
    background: var(--color-cream-dark);
    min-height: 100vh;
    padding: 3rem 1.5rem 5rem;
  }

  /* ── Document ── */
  .document {
    background: #fff;
    max-width: 760px;
    margin-inline: auto;
    padding: 3.5rem 4rem;
    border: 1px solid #ddd;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 1rem;
    line-height: 1.7;
    color: #111;
  }

  .document p { margin-bottom: 1.1rem; }

  .doc-sender { margin-bottom: 2rem; }
  .doc-sender p { margin: 0; line-height: 1.55; }

  .doc-date { margin-bottom: 1.5rem; }

  .doc-recipient { margin-bottom: 1.75rem; }
  .doc-recipient p { margin: 0; line-height: 1.55; }

  .doc-re { margin-bottom: 1.75rem; }

  .document ul {
    padding-left: 1.5rem;
    margin-bottom: 1.1rem;
  }
  .document ul li { margin-bottom: 0.4rem; }

  .checklist { list-style: none; padding-left: 0; }
  .checklist li { padding-left: 0; margin-bottom: 0.5rem; }

  .doc-sig {
    margin: 2rem 0 1.5rem;
  }
  .sig-line {
    width: 260px;
    border-bottom: 1px solid #888;
    margin-bottom: 0.5rem;
  }

  .doc-enclosures { font-size: 0.9rem; }

  .doc-footer-note {
    margin-top: 2rem;
    padding: 1rem 1.25rem;
    background: #f5f0e8;
    border-left: 3px solid #b08860;
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: #555;
    border-radius: 0 4px 4px 0;
  }
  .doc-footer-note p { margin: 0; }

  /* ── Placeholder styling ── */
  .document :global([data-fill]) {
    background: #fef9e7;
    border-bottom: 1px dashed #c8a86b;
    padding: 0 0.15em;
  }

  /* ── Print ── */
  @media print {
    .no-print { display: none !important; }
    .doc-wrap {
      background: #fff;
      padding: 0;
    }
    .document {
      box-shadow: none;
      border: none;
      padding: 0;
      max-width: 100%;
    }
  }

  @media (max-width: 600px) {
    .document { padding: 2rem 1.5rem; }
    .toolbar-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
