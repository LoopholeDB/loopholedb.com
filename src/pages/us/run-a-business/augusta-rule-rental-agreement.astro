---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
---

<Layout
  title="Augusta Rule Rental Agreement Template — LoopholeDB"
  description="Free fill-in-the-blank rental agreement template for the Augusta Rule (IRC § 280A(g)) — rent your home to your business tax-free. Print or save as PDF."
>
  <Nav />
  <main>
    <div class="template-toolbar no-print">
      <div class="toolbar-inner">
        <a href="/us/run-a-business/augusta-rule" class="toolbar-back">← The Augusta Rule</a>
        <div class="toolbar-actions">
          <p class="toolbar-hint">Fill in the <mark>[BRACKETED FIELDS]</mark>, then print or save as PDF.</p>
          <button onclick="window.print()" class="btn btn--primary">Print / Save as PDF</button>
        </div>
      </div>
    </div>

    <div class="doc-wrap">
      <article class="document">

        <h1 class="doc-title">SHORT-TERM RENTAL AGREEMENT</h1>
        <p class="doc-subtitle">IRC § 280A(g) — Fourteen-Day Home Rental Exemption</p>

        <div class="doc-section">
          <h2>PARTIES</h2>
          <table class="info-table">
            <tr>
              <td><strong>Landlord (Property Owner):</strong></td>
              <td>[YOUR FULL LEGAL NAME]</td>
            </tr>
            <tr>
              <td><strong>Landlord Address:</strong></td>
              <td>[YOUR HOME ADDRESS]</td>
            </tr>
            <tr>
              <td><strong>Tenant (Business):</strong></td>
              <td>[BUSINESS LEGAL NAME]</td>
            </tr>
            <tr>
              <td><strong>Business EIN / Entity Type:</strong></td>
              <td>[EIN] / [e.g., S-Corp, LLC, Sole Proprietor]</td>
            </tr>
            <tr>
              <td><strong>Business Address:</strong></td>
              <td>[BUSINESS ADDRESS]</td>
            </tr>
          </table>
        </div>

        <div class="doc-section">
          <h2>RENTAL PROPERTY</h2>
          <table class="info-table">
            <tr>
              <td><strong>Property Address:</strong></td>
              <td>[FULL PROPERTY ADDRESS]</td>
            </tr>
            <tr>
              <td><strong>Description:</strong></td>
              <td>[e.g., Primary residence, single-family home, approx. [SQ FT] sq ft, including [ROOM(S) USED, e.g., living room, dining room, and backyard]]</td>
            </tr>
          </table>
        </div>

        <div class="doc-section">
          <h2>RENTAL TERMS</h2>
          <table class="info-table">
            <tr>
              <td><strong>Rental Date(s):</strong></td>
              <td>[DATE(S) — list each individual rental day, e.g., January 15, 2026; March 8, 2026]</td>
            </tr>
            <tr>
              <td><strong>Total Days This Agreement:</strong></td>
              <td>[NUMBER] days</td>
            </tr>
            <tr>
              <td><strong>Cumulative Days Rented This Calendar Year:</strong></td>
              <td>[NUMBER] days (must not exceed 14 days total for the calendar year to qualify under IRC § 280A(g))</td>
            </tr>
            <tr>
              <td><strong>Purpose of Use:</strong></td>
              <td>[SPECIFIC BUSINESS PURPOSE — e.g., "Annual business planning retreat," "Board of directors meeting," "Client appreciation event," "Employee training session"]</td>
            </tr>
            <tr>
              <td><strong>Daily Rental Rate:</strong></td>
              <td>$[AMOUNT] per day</td>
            </tr>
            <tr>
              <td><strong>Total Rental Amount:</strong></td>
              <td>$[TOTAL AMOUNT]</td>
            </tr>
            <tr>
              <td><strong>Payment Due:</strong></td>
              <td>[DATE]</td>
            </tr>
            <tr>
              <td><strong>Payment Method:</strong></td>
              <td>[e.g., Business check / ACH transfer from business account to landlord's personal account]</td>
            </tr>
          </table>
        </div>

        <div class="doc-section">
          <h2>FAIR MARKET RENTAL RATE BASIS</h2>
          <p>
            The daily rate of $[AMOUNT] reflects the fair market rental value for a comparable space in the [CITY/AREA] area, based on the following comparable venues researched on [DATE OF RESEARCH]:
          </p>
          <table class="comp-table">
            <thead>
              <tr>
                <th>Comparable Venue</th>
                <th>Type / Size</th>
                <th>Rate</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>[VENUE NAME, e.g., Hotel XYZ — Conference Room]</td>
                <td>[e.g., 1,200 sq ft meeting room]</td>
                <td>$[RATE]/day</td>
              </tr>
              <tr>
                <td>[VENUE NAME, e.g., Airbnb listing at [URL/ADDRESS]]</td>
                <td>[e.g., 3-bedroom home, event use]</td>
                <td>$[RATE]/day</td>
              </tr>
              <tr>
                <td>[VENUE NAME]</td>
                <td>[Description]</td>
                <td>$[RATE]/day</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="doc-section">
          <h2>TERMS AND CONDITIONS</h2>
          <ol>
            <li>Tenant shall use the Property solely for the legitimate business purpose stated above.</li>
            <li>Tenant shall not sublease the Property or permit any use beyond the stated purpose.</li>
            <li>Tenant shall leave the Property in substantially the same condition as received.</li>
            <li>Landlord represents that they are the lawful owner of the Property and have full right to rent it.</li>
            <li>This Agreement, together with any meeting agendas and minutes from the rental day(s), constitutes the complete record of this rental arrangement.</li>
            <li>Landlord acknowledges that pursuant to IRC § 280A(g), rental income from a personal residence rented for 14 days or fewer in a calendar year is excluded from the landlord's gross income. Landlord will not report this income on Schedule E or any other schedule.</li>
            <li>Tenant will treat the rental payment as an ordinary and necessary business expense deductible under IRC § 162(a), subject to any applicable limitations.</li>
          </ol>
        </div>

        <div class="doc-section">
          <h2>SIGNATURES</h2>
          <div class="sig-block">
            <div class="sig-col">
              <div class="sig-line"></div>
              <p>[YOUR PRINTED NAME] — Landlord</p>
              <p>Date: ___________________</p>
            </div>
            <div class="sig-col">
              <div class="sig-line"></div>
              <p>[NAME], [TITLE] — on behalf of [BUSINESS NAME]</p>
              <p>Date: ___________________</p>
            </div>
          </div>
        </div>

        <div class="doc-footer-note no-print">
          <p><strong>Retain this document with your tax records.</strong> Also keep: meeting agendas and minutes for each rental day, proof of payment (cancelled check or bank transfer record), and your comparable venue research. The IRS has increased scrutiny of Augusta Rule arrangements — thorough documentation is essential. Consult a tax professional if you have questions about your specific situation.</p>
        </div>

      </article>
    </div>
  </main>
  <div class="no-print"><Footer /></div>
</Layout>

<style>
  .template-toolbar {
    background: var(--color-espresso);
    padding: 0.85rem 0;
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .toolbar-inner {
    max-width: var(--max-w);
    margin-inline: auto;
    padding-inline: 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .toolbar-back {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(242,235,224,0.6);
    transition: color var(--transition);
    white-space: nowrap;
  }
  .toolbar-back:hover { color: var(--color-cream); }
  .toolbar-actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .toolbar-hint {
    font-size: var(--text-sm);
    color: rgba(242,235,224,0.55);
  }
  .toolbar-hint mark {
    background: rgba(242,235,224,0.15);
    color: var(--color-cream);
    border-radius: 3px;
    padding: 0.1em 0.3em;
  }

  .doc-wrap {
    background: var(--color-cream-dark);
    min-height: 100vh;
    padding: 3rem 1.5rem 5rem;
  }

  .document {
    background: #fff;
    max-width: 760px;
    margin-inline: auto;
    padding: 3.5rem 4rem;
    border: 1px solid #ddd;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 1rem;
    line-height: 1.7;
    color: #111;
  }

  .document p { margin-bottom: 1.1rem; }

  .doc-title {
    font-family: Georgia, serif;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-align: center;
    margin-bottom: 0.5rem;
  }
  .doc-subtitle {
    text-align: center;
    font-style: italic;
    color: #555;
    margin-bottom: 2.5rem;
  }

  .doc-section {
    margin-bottom: 2rem;
  }
  .doc-section h2 {
    font-family: Georgia, serif;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border-bottom: 1px solid #bbb;
    padding-bottom: 0.3rem;
    margin-bottom: 1rem;
  }

  .info-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }
  .info-table td {
    padding: 0.4rem 0.75rem 0.4rem 0;
    vertical-align: top;
    border-bottom: 1px solid #eee;
  }
  .info-table td:first-child {
    width: 220px;
    color: #444;
    white-space: nowrap;
  }

  .comp-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    margin-top: 0.75rem;
  }
  .comp-table th {
    text-align: left;
    padding: 0.4rem 0.75rem 0.4rem 0;
    border-bottom: 2px solid #bbb;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .comp-table td {
    padding: 0.45rem 0.75rem 0.45rem 0;
    border-bottom: 1px solid #eee;
    vertical-align: top;
  }

  .document ol {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .document ol li {
    margin-bottom: 0.5rem;
    line-height: 1.65;
  }

  .sig-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-top: 1.5rem;
  }
  .sig-col p {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .sig-line {
    border-bottom: 1px solid #888;
    margin-bottom: 0.5rem;
    height: 2.5rem;
  }

  .doc-footer-note {
    margin-top: 2rem;
    padding: 1rem 1.25rem;
    background: #f5f0e8;
    border-left: 3px solid #b08860;
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: #555;
    border-radius: 0 4px 4px 0;
  }
  .doc-footer-note p { margin: 0; }

  @media print {
    .no-print { display: none !important; }
    .doc-wrap { background: #fff; padding: 0; }
    .document { box-shadow: none; border: none; padding: 0; max-width: 100%; }
    .sig-block { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 600px) {
    .document { padding: 2rem 1.5rem; }
    .toolbar-inner { flex-direction: column; align-items: flex-start; }
    .info-table td:first-child { width: auto; white-space: normal; }
    .sig-block { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
