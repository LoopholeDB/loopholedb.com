              regard to conflict of law principles. Any dispute arising out of or relating to
              these Terms or your use of the Site shall be subject to the exclusive jurisdiction
              of the courts located in Ontario, Canada.
            </p>
          </section>

          <section id="contact">
            <h2>11. Contact</h2>
            <p>
              If you have questions about these Terms, please contact us at:
            </p>
            <p>
              <a href="mailto:followmoney.ca@gmail.com">followmoney.ca@gmail.com</a>
            </p>
          </section>

        </article>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* ── Hero ─────────────────────────────────────────── */
  .hero { padding-block: 4rem 3rem; }
  .hero__inner { display: flex; flex-direction: column; gap: 1rem; }
  .hero__title {
    color: var(--color-cream);
    text-transform: none;
    letter-spacing: 0.02em;
    font-size: clamp(2rem, 4vw, 3rem);
  }
  .hero__meta {
    font-size: var(--text-xs);
    color: rgba(242,235,224,0.4);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* ── Layout ───────────────────────────────────────── */
  .page__inner {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 5rem;
    align-items: start;
  }

  /* ── TOC ──────────────────────────────────────────── */
  .toc {
    position: sticky;
    top: 5rem;
    background: var(--color-cream-dark);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.25rem 1.5rem;
  }
  .toc__heading {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.85rem;
  }
  .toc ol {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    list-style: none;
    padding: 0;
    counter-reset: toc;
  }
  .toc a {
    font-size: var(--text-sm);
    color: var(--color-text-mid);
    transition: color var(--transition);
    line-height: 1.4;
  }
  .toc a:hover { color: var(--color-text-dark); }

  /* ── Prose ────────────────────────────────────────── */
  .prose {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .prose section {
    padding-bottom: 2.5rem;
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .prose section:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .prose h2 {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.5vw, 1.7rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-dark);
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .prose p {
    color: var(--color-text-mid);
    line-height: 1.85;
    margin-bottom: 1rem;
    font-size: var(--text-body);
  }
  .prose p:last-child { margin-bottom: 0; }

  .prose strong {
    font-weight: 600;
    color: var(--color-text-dark);
  }

  .prose ul, .prose ol {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .prose ul { list-style: disc; }
  .prose ol { list-style: decimal; }

  .prose li {
    color: var(--color-text-mid);
    line-height: 1.75;
    font-size: var(--text-body);
  }

  .prose a {
    color: var(--color-brown-cta);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(75,53,32,0.3);
    transition: text-decoration-color var(--transition);
  }
  .prose a:hover { text-decoration-color: var(--color-brown-cta); }

  /* ── Responsive ───────────────────────────────────── */
  @media (max-width: 768px) {
    .page__inner { grid-template-columns: 1fr; }
    .toc { position: static; }
  }
</style>
